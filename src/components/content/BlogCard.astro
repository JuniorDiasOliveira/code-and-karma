---
import Icon from '../ui/Icon.astro';

interface Props {
  slug: string;
  title: string;
  excerpt: string;
  date: string;
  tags: string[];
  readTime: string;
}

const { slug, title, excerpt, date, tags, readTime } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<a
  href={`/post/${slug}`}
  data-blog-card
  data-tags={tags.join(',')}
  class="group flex h-full overflow-hidden rounded-lg border border-border bg-card/50 backdrop-blur-sm transition-all duration-300 hover:border-primary/50 hover:neon-border-glow"
>
  <article class="flex h-full w-full flex-col p-6">
    <div class="mb-3 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="inline-flex items-center rounded-full border border-secondary/30 bg-secondary/20 px-2.5 py-0.5 text-xs font-medium text-secondary hover:bg-secondary/30">
          {tag}
        </span>
      ))}
    </div>

    <h3 class="mb-2 text-2xl font-semibold transition-all group-hover:neon-gradient-text">
      {title}
    </h3>

    <p class="mt-2 mb-4 min-h-[4.5rem] line-clamp-3 text-muted-foreground">
      {excerpt}
    </p>

    <footer class="mt-auto flex items-center gap-4 text-sm text-muted-foreground">
      <div class="flex items-center gap-1">
        <Icon name="calendar" size="sm" />
        <span>{formattedDate}</span>
      </div>

      <div class="flex items-center gap-1">
        <Icon name="clock" size="sm" />
        <span>{readTime}</span>
      </div>
    </footer>
  </article>
</a>
